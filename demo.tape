# Don Cheli — SDD Framework Demo
# Run: vhs demo.tape

Output demo.gif

Set Shell "bash"
Set FontSize 16
Set Width 1200
Set Height 600
Set Theme "Catppuccin Mocha"
Set Padding 20
Set TypingSpeed 50ms

# Title
Type "# 🏗️ Don Cheli v1.13.0 — SDD Framework"
Enter
Sleep 1s

Type "# Stop guessing. Start Engineering."
Enter
Sleep 1.5s

# Install
Type "curl -fsSL https://raw.githubusercontent.com/doncheli/don-cheli-sdd/main/scripts/instalar.sh | bash -s -- --global --lang en"
Sleep 500ms
Enter
Sleep 4s

# Clear and show commands
Type "clear"
Enter
Sleep 500ms

Type "# 72+ commands, 43 skills, 15 reasoning models"
Enter
Sleep 1s

# Start a task
Type "/dc:start Implement JWT authentication with refresh tokens"
Sleep 500ms
Enter
Sleep 2s

Type "# ✅ Complexity detected: Level 2 (Standard)"
Enter
Sleep 1s

Type "# 📋 Generating Gherkin spec..."
Enter
Sleep 1s

Type "# 🏗️ Creating technical blueprint..."
Enter
Sleep 1s

Type "# 🧪 Breaking down into TDD tasks (RED → GREEN → REFACTOR)..."
Enter
Sleep 1.5s

# Show pipeline
Type "clear"
Enter
Sleep 500ms

Type "# The Don Cheli Pipeline"
Enter
Sleep 500ms

Type "echo ''"
Enter

Type "echo '  /dc:pre-mortem       → Anticipate failure before coding'"
Enter
Sleep 300ms

Type "echo '  /dc:estimate         → COCOMO + Planning Poker AI'"
Enter
Sleep 300ms

Type "echo '  /dc:specify          → Gherkin spec + DBML schema'"
Enter
Sleep 300ms

Type "echo '  /dc:tech-plan        → Technical blueprint'"
Enter
Sleep 300ms

Type "echo '  /dc:implement        → TDD: RED → GREEN → REFACTOR'"
Enter
Sleep 300ms

Type "echo '  /dc:security-audit   → OWASP Top 10'"
Enter
Sleep 300ms

Type "echo '  /dc:review           → 7-dimension peer review'"
Enter
Sleep 1.5s

# Reasoning models
Type "clear"
Enter
Sleep 500ms

Type "# 15 Reasoning Models"
Enter
Sleep 500ms

Type "echo '  /razonar:pre-mortem         → Anticipate failure'"
Enter
Sleep 200ms

Type "echo '  /razonar:5-porques          → Root cause analysis'"
Enter
Sleep 200ms

Type "echo '  /razonar:pareto             → 80/20 focus'"
Enter
Sleep 200ms

Type "echo '  /razonar:inversion          → Think backwards'"
Enter
Sleep 200ms

Type "echo '  /razonar:primeros-principios → First principles'"
Enter
Sleep 200ms

Type "echo '  /razonar:rlm-*              → 3 RLM models with sub-LLMs'"
Enter
Sleep 1.5s

# Debate
Type "clear"
Enter
Sleep 500ms

Type "# Multi-role expert panels"
Enter
Sleep 500ms

Type "echo '/dc:debate       → Adversarial tension (CPO vs Architect vs QA)'"
Enter
Sleep 300ms

Type "echo '/dc:roundtable   → Exploratory discussion (CPO, UX, Business)'"
Enter
Sleep 300ms

Type "echo '/dc:tech-panel   → Senior dev experts (Tech Lead, Backend, Frontend, Architect, DevOps)'"
Enter
Sleep 1.5s

# Final
Type "clear"
Enter
Sleep 500ms

Type "echo ''"
Enter

Type "echo '  🏗️ Don Cheli v1.13.0'"
Enter

Type "echo '  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━'"
Enter

Type "echo '  72+ commands · 43 skills · 15 reasoning models'"
Enter

Type "echo '  TDD as iron law · OWASP audit · Team planning'"
Enter

Type "echo '  Languages: EN | ES | PT'"
Enter

Type "echo ''"
Enter

Type "echo '  github.com/doncheli/don-cheli-sdd'"
Enter

Type "echo '  npm install don-cheli-sdd'"
Enter

Type "echo ''"
Enter

Type "echo '  Stop guessing. Start Engineering.'"
Enter

Sleep 3s
